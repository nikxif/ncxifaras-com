---
// writing.astro — the curated surface: featured pieces only. A filtered VIEW
// over the one blog collection (D3), not a second collection.
import BaseLayout from '../layouts/BaseLayout.astro';
import PostCard from '../components/PostCard.astro';
import SectionHead from '../components/SectionHead.astro';
import { getFeaturedPosts, getPublishedPosts } from '../lib/posts';

const featured = await getFeaturedPosts();
const all = await getPublishedPosts();
---

<BaseLayout
  title="Selected writing — Nick Xifaras"
  description="Selected pieces: the work I'd hand someone first."
>
  <section class="container">
    <SectionHead
      title="Selected writing"
      count={featured.length}
      moreHref="/posts"
      moreLabel={`everything (${all.length}) →`}
    />
    {
      featured.length > 0 ? (
        <div class="list">
          {featured.map((p) => (
            <PostCard post={p} featured />
          ))}
        </div>
      ) : (
        <p class="text-lede">Nothing marked as featured yet — see <a href="/posts">all posts</a>.</p>
      )
    }
  </section>
</BaseLayout>

<style>
  section {
    padding-block: var(--space-6) var(--space-4);
  }

  .list {
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
    max-width: var(--width-content);
  }
</style>
