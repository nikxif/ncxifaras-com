---
// tags/[tag].astro — posts filtered by tag.
import type { GetStaticPaths } from 'astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import PostCard from '../../components/PostCard.astro';
import SectionHead from '../../components/SectionHead.astro';
import { getPublishedPosts, getAllTags } from '../../lib/posts';

export const getStaticPaths = (async () => {
  const [posts, tags] = await Promise.all([getPublishedPosts(), getAllTags()]);
  return tags.map((tag) => ({
    params: { tag },
    props: { posts: posts.filter((p) => p.data.tags.includes(tag)), tag },
  }));
}) satisfies GetStaticPaths;

const { posts, tag } = Astro.props;
---

<BaseLayout title={`#${tag} — Nick Xifaras`} description={`Posts tagged ${tag}.`}>
  <section class="container">
    <SectionHead title={`#${tag}`} count={posts.length} moreHref="/posts" moreLabel="all posts →" />
    <div class="list">
      {posts.map((p) => <PostCard post={p} />)}
    </div>
  </section>
</BaseLayout>

<style>
  section {
    padding-block: var(--space-6) var(--space-4);
  }

  .list {
    display: flex;
    flex-direction: column;
    gap: var(--space-5);
    max-width: var(--width-content);
  }
</style>
