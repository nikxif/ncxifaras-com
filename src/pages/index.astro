---
// index.astro — the landing page. Positioning first (hero as thesis),
// then featured + recent writing. NOT a blog river (ARCHITECTURE.md).
import BaseLayout from '../layouts/BaseLayout.astro';
import PostCard from '../components/PostCard.astro';
import SectionHead from '../components/SectionHead.astro';
import { getPublishedPosts } from '../lib/posts';

const posts = await getPublishedPosts();
const featured = posts.filter((p) => p.data.featured);
// Lead with the newest featured post if there is one, else the newest post.
const lead = featured[0] ?? posts[0];
const rest = posts.filter((p) => p !== lead).slice(0, 3);
---

<BaseLayout
  title="Nick Xifaras — physician & software developer"
  description="A doctor who writes code, working across clinical medicine, digital-health policy, and the messy seams between them. Moving toward neuroscience and brain–computer interfaces."
>
  <section class="container hero">
    <div>
      <p class="eyebrow">physician / software developer · athens</p>
      <h1>
        I build the tools<br />clinical work <span class="amp">&amp;</span><br />keeps
        breaking.
      </h1>
      <p class="text-lede lede">
        A doctor who writes code, working across clinical medicine, digital-health
        policy, and the messy seams between them.
      </p>
      <p class="pivot">
        Lately I'm moving toward neuroscience, neurorehabilitation, and
        brain–computer interfaces — where the clinical and the computational stop
        being separate jobs.
      </p>
    </div>
    <div class="motif" aria-hidden="true">
      <div class="disc"></div>
      <div class="barv"></div>
      <div class="ring"></div>
      <div class="sq"></div>
    </div>
  </section>

  {
    posts.length > 0 && (
      <section class="container writing">
        <SectionHead title="Writing" count={`${posts.length} pieces`} moreHref="/posts" moreLabel="all posts →" />
        <div class="feature">
          <PostCard post={lead} featured />
        </div>
        {rest.length > 0 && (
          <div class="grid">
            {rest.map((p) => (
              <PostCard post={p} />
            ))}
          </div>
        )}
      </section>
    )
  }
</BaseLayout>

<style>
  .hero {
    display: grid;
    grid-template-columns: 1fr 16rem;
    gap: var(--space-6);
    align-items: start;
    padding-block: var(--space-6) var(--space-5);
  }

  .eyebrow {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--cobalt-deep);
    letter-spacing: 0.04em;
    margin-bottom: var(--space-3);
  }

  h1 {
    margin-bottom: var(--space-4);
  }

  .amp {
    color: var(--vermilion);
  }

  .lede {
    max-width: 38ch;
    margin-bottom: var(--space-3);
  }

  .pivot {
    color: var(--ink-soft);
    max-width: 46ch;
  }

  /* Geometric motif — same visual vocabulary as the generated covers */
  .motif {
    position: relative;
    height: 15rem;
    margin-top: var(--space-2);
  }

  .motif .disc {
    position: absolute;
    width: 7.4rem;
    height: 7.4rem;
    border-radius: 50%;
    background: var(--cobalt);
    top: 0;
    right: 1.2rem;
  }

  .motif .barv {
    position: absolute;
    width: 2.1rem;
    height: 12rem;
    background: var(--vermilion);
    top: 1.6rem;
    right: 6rem;
  }

  .motif .ring {
    position: absolute;
    width: 3.7rem;
    height: 3.7rem;
    border: 6px solid var(--ink);
    border-radius: 50%;
    bottom: 1.6rem;
    right: 9.4rem;
  }

  .motif .sq {
    position: absolute;
    width: 4.4rem;
    height: 4.4rem;
    background: var(--ochre);
    bottom: 0.5rem;
    right: 0;
  }

  .writing {
    padding-block: var(--space-5) var(--space-4);
  }

  .feature {
    margin-bottom: var(--space-5);
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-5);
  }

  @media (max-width: 820px) {
    .hero {
      grid-template-columns: 1fr;
    }

    .motif {
      display: none;
    }

    .grid {
      grid-template-columns: 1fr;
      gap: var(--space-5);
    }
  }
</style>
