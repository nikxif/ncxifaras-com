---
// cv.astro — data lives in src/data/cv.yaml now; this file is just presentation.
// Astro imports YAML natively, so `cv` is the parsed object. Editing the CV =
// editing the YAML. The rendering below is unchanged from the inline version.
import BaseLayout from '../layouts/BaseLayout.astro';
import cv from '../data/cv.yaml';
---

<BaseLayout
  title="CV — Nick Xifaras"
  description="Curriculum vitae: physician & software developer, Athens."
>
  <section class="container cv">
    <h1>Curriculum vitae</h1>
    <p class="summary">{cv.summary}</p>
    <p class="text-meta">
      Full PDF version available on request · <a href="mailto:info@ncxifaras.com">info@ncxifaras.com</a>
    </p>

    {
      cv.sections.map((s) => (
        <section class="block">
          <h2>{s.heading}</h2>
          {s.items.map((it) => (
            <article class="item">
              <div class="row">
                <h3>{it.title}</h3>
                {it.period && <span class="text-meta">{it.period}</span>}
              </div>
              {it.org && <p class="org">{it.org}</p>}
              {it.notes.length > 0 && (
                <ul>
                  {it.notes.map((n) => (
                    <li>{n}</li>
                  ))}
                </ul>
              )}
            </article>
          ))}
        </section>
      ))
    }
  </section>
</BaseLayout>

<style>
  .cv {
    max-width: var(--width-content);
    padding-block: var(--space-6);
  }

  .summary {
    font-size: var(--text-lg);
    line-height: 1.5;
    margin-block: var(--space-3);
    max-width: 52ch;
  }

  .block {
    margin-top: var(--space-5);
  }

  .block h2 {
    font-size: var(--text-lg);
    border-bottom: var(--border-hair);
    padding-bottom: var(--space-1);
    margin-bottom: var(--space-3);
  }

  .item + .item {
    margin-top: var(--space-3);
  }

  .row {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: var(--space-3);
  }

  .row h3 {
    font-size: 1.05rem;
  }

  .org {
    color: var(--ink-soft);
    font-size: 1rem;
  }

  .item ul {
    margin-top: var(--space-1);
    padding-left: 1.3em;
    color: var(--ink-soft);
    font-size: 1rem;
  }
</style>
