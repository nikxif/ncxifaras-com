---
// about.astro — now a thin shell. All the copy lives in
// src/content/pages/about.md, so editing the page means editing markdown.
//
// Same pattern works for any other prose page (uses, now, colophon…): add a
// .md file to src/content/pages/ and copy this file with the id changed.
import { getEntry, render } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';

const page = await getEntry('pages', 'about');
if (!page) {
  // Fail loudly at build time rather than shipping an empty page.
  throw new Error('Missing src/content/pages/about.md');
}
const { Content } = await render(page);
---

<BaseLayout
  title={`${page.data.title} — Nick Xifaras`}
  description={page.data.description}
>
  <section class="container page">
    <h1>{page.data.title}</h1>
    <div class="prose">
      <Content />
    </div>
  </section>
</BaseLayout>

<style>
  .page {
    max-width: var(--width-content);
    padding-block: var(--space-6);
  }

  .page h1 {
    margin-bottom: var(--space-4);
  }
</style>
