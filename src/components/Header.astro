---
// Header.astro — Phase 2 revision: "Writing" now points at the curated
// /writing view (per ARCHITECTURE routes); /posts is the full archive,
// reachable from /writing and the homepage's "all posts →".
const nav = [
  { href: '/about', label: 'About' },
  { href: '/cv', label: 'CV'},
  { href: '/posts', label: 'Blog' },
  { href: '/writing', label: 'Writing' }
];

const { pathname } = Astro.url;
const isActive = (href: string) =>
  pathname === href || (href !== '/' && pathname.startsWith(href + '/'));
---

<header class="site-header">
  <div class="container bar">
    <a href="/" class="mark link-plain" aria-label="Home">
      ncxifaras<span class="dot">.</span>com
    </a>
    <nav aria-label="Main">
      <ul>
        {
          nav.map((item) => (
            <li>
              <a
                href={item.href}
                class="link-plain nav-link"
                aria-current={isActive(item.href) ? 'page' : undefined}
              >
                {item.label}
              </a>
            </li>
          ))
        }
      </ul>
    </nav>
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 10;
    background: var(--paper);
    border-bottom: var(--border-strong);
  }

  .bar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 4rem;
  }

  .mark {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    font-weight: var(--weight-medium);
    letter-spacing: 0.02em;
  }

  .dot {
    color: var(--cobalt);
    font-weight: 700;
  }

  nav ul {
    display: flex;
    gap: var(--space-4);
    list-style: none;
    padding: 0;
  }

  .nav-link {
    font-family: var(--font-display);
    font-size: 0.94rem;
    font-weight: 600;
    padding-bottom: 2px;
    border-bottom: 2px solid transparent;
    transition: border-color var(--transition-quick);
  }

  .nav-link:hover,
  .nav-link[aria-current='page'] {
    border-color: var(--cobalt);
    color: inherit;
  }

  @media (max-width: 640px) {
    nav ul {
      gap: var(--space-3);
    }
  }
</style>
