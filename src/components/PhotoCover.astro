---
// PhotoCover.astro — real photos, duotoned into the category colour so they
// cohere with the generated covers (D12).
//
// FIXED (two bugs):
//  1. `src` is now ImageMetadata ONLY, never a raw string. The schema's
//     image() helper resolves the frontmatter path relative to the markdown
//     file at build time; <Image> then emits the hashed /_astro/ URL. The old
//     raw-<img> string branch emitted the author-relative path verbatim, which
//     the browser resolved against the PAGE url → 404 (broken cover, while the
//     same path worked in the post body, which markdown rewrites).
//  2. The duotone ramp used `var(--duo-r)` inside SVG *attributes*. SVG
//     attributes aren't CSS, so var() never resolved (and those vars were
//     never defined). Ramp values are now real numbers computed from the
//     palette — verified rendering across all four categories.
import { Image } from 'astro:assets';
import { CATEGORY_LABELS } from '../lib/posts';
import { duotoneRamp, type Category } from '../lib/palette';

interface Props {
  /** Must be ImageMetadata — i.e. a `cover` field typed with image() in the schema. */
  src: ImageMetadata;
  alt: string;
  category: Category;
  title?: string;
}
const { src, alt, category, title } = Astro.props;
const label = CATEGORY_LABELS[category];

const [rampR, rampG, rampB] = duotoneRamp(category);

// Unique per instance: several photo covers can share one index page, and
// duplicate filter ids would make every one of them use the first filter.
const filterId = `duo-${category}-${Math.random().toString(36).slice(2, 9)}`;
---

<figure class:list={['pcover', `cat-${category}`]}>
  <Image
    src={src}
    alt={alt}
    width={720}
    height={450}
    class="duo-img"
    style={`filter: url(#${filterId})`}
    loading="lazy"
  />

  {/* Filter travels with the component. Sized 0 rather than display:none —
      some browsers drop filter refs inside a display:none subtree. */}
  <svg class="duo-def" aria-hidden="true" focusable="false">
    <filter id={filterId} color-interpolation-filters="sRGB">
      {/* 1. luminance (Rec. 709 weights — perceptually correct, unlike a flat 0.33 split) */}
      <feColorMatrix
        type="matrix"
        values="0.2126 0.7152 0.0722 0 0
                0.2126 0.7152 0.0722 0 0
                0.2126 0.7152 0.0722 0 0
                0      0      0      1 0"
      />
      {/* 2. map that greyscale ramp onto ink → category colour → paper */}
      <feComponentTransfer>
        <feFuncR type="table" tableValues={rampR} />
        <feFuncG type="table" tableValues={rampG} />
        <feFuncB type="table" tableValues={rampB} />
      </feComponentTransfer>
    </filter>
  </svg>

  <span class="pcover-label text-meta">{label}</span>
  {title && <figcaption class="pcover-title">{title}</figcaption>}
</figure>

<style>
  .pcover {
    position: relative;
    aspect-ratio: 16 / 10;
    border: var(--border-strong);
    border-radius: var(--radius);
    overflow: hidden;
    margin: 0;
    background: var(--paper-2);
  }

  .duo-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .duo-def {
    position: absolute;
    width: 0;
    height: 0;
  }

  .pcover-label {
    position: absolute;
    top: 0.7rem;
    left: 0.7rem;
    background: color-mix(in srgb, var(--paper) 78%, transparent);
    color: var(--ink);
    padding: 0.2rem 0.45rem;
    border-radius: var(--radius);
    font-weight: var(--weight-medium);
  }

  .pcover-title {
    position: absolute;
    left: 0.9rem;
    right: 0.9rem;
    bottom: 0.7rem;
    font-family: var(--font-display);
    font-weight: var(--weight-heading);
    font-size: 1.05rem;
    line-height: 1.1;
    color: var(--paper);
    text-shadow: 0 1px 3px rgba(0, 0, 0, 0.5);
  }
</style>
