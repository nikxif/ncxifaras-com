---
// GeneratedCover.astro — no-photo Bauhaus cover.
// Geometry now comes from src/lib/cover-geometry.ts (shared with the OG image
// generator so they can't drift). Colours are passed as CSS vars, so tuning
// --cobalt / --vermilion / --ochre in tokens.css still flows through here.
import { coverInnerSVG } from '../lib/cover-geometry';
import type { Category } from '../lib/palette';
import { CATEGORY_LABELS } from '../lib/posts';

interface Props {
  category: Category;
  slug: string;
  title?: string;
}
const { category, slug, title } = Astro.props;

const inner = coverInnerSVG(slug, {
  cat: `var(--cat-${category})`,
  ink: 'var(--ink)',
  paper2: 'var(--paper-2)',
});
const label = CATEGORY_LABELS[category];
---

<div class:list={['gcover', `cat-${category}`]} aria-hidden={!title}>
  <svg
    viewBox="0 0 160 100"
    preserveAspectRatio="xMidYMid slice"
    role="img"
    aria-label={title ? `Cover for ${title}` : `${label} post`}
  >
    <Fragment set:html={inner} />
  </svg>

  <span class="gcover-label text-meta">{label}</span>
  {title && <span class="gcover-title">{title}</span>}
</div>

<style>
  .gcover {
    position: relative;
    aspect-ratio: 16 / 10;
    border: var(--border-strong);
    border-radius: var(--radius);
    overflow: hidden;
  }

  .gcover svg {
    display: block;
    width: 100%;
    height: 100%;
  }

  .gcover-label {
    position: absolute;
    top: 0.7rem;
    left: 0.7rem;
    background: color-mix(in srgb, var(--paper) 78%, transparent);
    color: var(--ink);
    padding: 0.2rem 0.45rem;
    border-radius: var(--radius);
    font-weight: var(--weight-medium);
  }

  .gcover-title {
    position: absolute;
    left: 0.9rem;
    right: 0.9rem;
    bottom: 0.7rem;
    font-family: var(--font-display);
    font-weight: var(--weight-heading);
    font-size: 1.05rem;
    line-height: 1.1;
    color: var(--ink);
    text-shadow: 0 1px 0 color-mix(in srgb, var(--paper) 60%, transparent);
  }
</style>
