---
// PostCard.astro — Phase 3-fixes: adds a `compact` variant (cover left, small,
// text right) for list pages like /posts and /tags, so archive covers aren't
// full-width. `featured` stays the big side-by-side; default stacks.
import Cover from './Cover.astro';
import { CATEGORY_LABELS, formatDate, type Post } from '../lib/posts';

interface Props {
  post: Post;
  featured?: boolean;
  compact?: boolean;
}

const { post, featured = false, compact = false } = Astro.props;
const { title, description, pubDate, category } = post.data;
const href = `/posts/${post.id}`;
---

<article class:list={['card', { featured, compact }]}>
  <a href={href} class="link-plain cover-link" tabindex="-1" aria-hidden="true">
    <Cover {post} />
  </a>
  <div class="body">
    <div class="meta text-meta">
      <span class:list={['chip', `cat-${category}`]}>{CATEGORY_LABELS[category]}</span>
      <time datetime={pubDate.toISOString()}>{formatDate(pubDate)}</time>
    </div>
    <h3 class="title">
      <a href={href} class="link-plain">{title}</a>
    </h3>
    <p class="dek">{description}</p>
  </div>
</article>

<style>
  .card {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .cover-link {
    display: block;
  }

  .body {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  /* Feature: big cover left, text right */
  .featured {
    display: grid;
    grid-template-columns: 22rem 1fr;
    gap: var(--space-5);
    align-items: center;
  }

  /* Compact: small cover left, text right — for list/archive pages */
  .compact {
    display: grid;
    grid-template-columns: 12rem 1fr;
    gap: var(--space-4);
    align-items: center;
  }

  .meta {
    display: flex;
    align-items: center;
    gap: var(--space-3);
  }

  .chip {
    display: inline-flex;
    align-items: center;
    gap: 0.45em;
    font-weight: var(--weight-medium);
  }

  .chip::before {
    content: '';
    width: 0.62em;
    height: 0.62em;
    border-radius: 1px;
    background: var(--_cat, var(--ink));
  }

  .cat-osint    { --_cat: var(--cat-osint); }
  .cat-policy   { --_cat: var(--cat-policy); }
  .cat-tutorial { --_cat: var(--cat-tutorial); }
  .cat-note     { --_cat: var(--cat-note); }

  .title {
    font-size: var(--text-xl);
    line-height: var(--leading-snug);
  }

  .featured .title {
    font-size: var(--text-2xl);
  }

  .compact .title {
    font-size: var(--text-lg);
  }

  .title a:hover {
    color: var(--cobalt-deep);
  }

  .dek {
    color: var(--ink-soft);
    font-size: 1rem;
    line-height: 1.5;
    max-width: 52ch;
  }

  .featured .dek {
    font-size: var(--text-base);
    color: var(--ink);
  }

  .compact .dek {
    font-size: 0.95rem;
    /* keep archive rows tight: clamp the dek to 2 lines */
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  @media (max-width: 640px) {
    .featured,
    .compact {
      grid-template-columns: 1fr;
      gap: var(--space-3);
    }

    /* On phones, don't shrink the compact cover to a sliver — let it stack. */
    .compact .dek {
      -webkit-line-clamp: 3;
    }
  }
</style>
