---
// Footer.astro — mirrors the header's language: strong rule, mono links.
const links = [
  { href: '/rss.xml', label: 'RSS' },
  { href: 'https://github.com/nikxif', label: 'GitHub' }, // TODO: real profile URL
  { href: 'https://medium.com/@nixifaras', label: 'Medium' }, // TODO: real profile URL
  { href: 'mailto:info@ncxifaras.com', label: 'Email' },
];

const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="container row">
    <div class="fmark">
      ncxifaras.com
      <span class="text-meta">© {year} · Nick Xifaras</span>
    </div>
    <nav aria-label="Elsewhere">
      <ul>
        {
          links.map((l) => (
            <li>
              <a href={l.href} class="link-plain flink">
                {l.label}
              </a>
            </li>
          ))
        }
      </ul>
    </nav>
  </div>
</footer>

<style>
  .site-footer {
    margin-top: var(--space-7);
    border-top: var(--border-strong);
    padding-block: var(--space-4) var(--space-6);
  }

  .row {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    flex-wrap: wrap;
    gap: var(--space-3);
  }

  .fmark {
    font-family: var(--font-display);
    font-weight: var(--weight-display);
    font-size: 1.15rem;
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
  }

  ul {
    display: flex;
    gap: var(--space-4);
    list-style: none;
    padding: 0;
  }

  .flink {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--ink-soft);
    transition: color var(--transition-quick);
  }

  .flink:hover {
    color: var(--cobalt-deep);
  }
</style>
