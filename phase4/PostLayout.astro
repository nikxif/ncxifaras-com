---
// PostLayout.astro — renders a single post. Replaces the starter's
// BlogPost.astro (which can now be deleted along with BaseHead).
// Prose column is --width-content; the extra room to the right is where
// sidenotes will live in Phase 3.
import BaseLayout from './BaseLayout.astro';
import { CATEGORY_LABELS, formatDate, type Post } from '../lib/posts';

interface Props {
  post: Post;
}

const { post } = Astro.props;
const { title, description, pubDate, updatedDate, category, tags, canonicalURL } =
  post.data;
---

<BaseLayout
  title={`${title} — Nick Xifaras`}
  {description}
  {canonicalURL}
  ogImage={`/og/${post.id}.png`}
>
  <article class="container post">
    <header class="post-head">
      <p class="meta text-meta">
        <span class:list={['chip', `cat-${category}`]}>{CATEGORY_LABELS[category]}</span>
        <time datetime={pubDate.toISOString()}>{formatDate(pubDate)}</time>
        {
          updatedDate && (
            <span>
              · updated <time datetime={updatedDate.toISOString()}>{formatDate(updatedDate)}</time>
            </span>
          )
        }
      </p>
      <h1>{title}</h1>
      <p class="text-lede dek">{description}</p>
    </header>

    <div class="prose">
      <slot />
    </div>

    {
      tags.length > 0 && (
        <footer class="post-foot">
          <ul class="tags">
            {tags.map((t) => (
              <li>
                <a href={`/tags/${t}`} class="link-plain tag">
                  #{t}
                </a>
              </li>
            ))}
          </ul>
        </footer>
      )
    }
  </article>
</BaseLayout>

<style>
  .post {
    max-width: var(--width-content);
    padding-block: var(--space-6) var(--space-5);
  }

  /* On wide screens (only once there's real room), widen the article to fit
     the text column + a right-hand margin column, and centre the whole thing.
     The text itself (header, prose, footer) stays capped at --width-content on
     the left; sidenotes are positioned into the reserved right-hand space by
     Sidenote.astro. Breakpoint = content(46) + gap(2) + note(16) + page
     margins ≈ 70rem, so notes never get clipped. */
  @media (min-width: 70rem) {
    .post {
      max-width: calc(var(--width-content) + 2rem + var(--width-sidenote));
      margin-inline: auto;
    }

    .post-head,
    .post-foot,
    .prose {
      max-width: var(--width-content);
    }
    /* NB: the paragraph positioning-context rule lives in the is:global block
       below — markdown-generated <p> elements don't carry this component's
       scope hash, so a scoped selector wouldn't reach them. */
  }

  .post-head {
    margin-bottom: var(--space-5);
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .meta {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    flex-wrap: wrap;
  }

  .chip {
    display: inline-flex;
    align-items: center;
    gap: 0.45em;
    font-weight: var(--weight-medium);
  }

  .chip::before {
    content: '';
    width: 0.62em;
    height: 0.62em;
    border-radius: 1px;
    background: var(--_cat, var(--ink));
  }

  .cat-osint    { --_cat: var(--cat-osint); }
  .cat-policy   { --_cat: var(--cat-policy); }
  .cat-tutorial { --_cat: var(--cat-tutorial); }
  .cat-note     { --_cat: var(--cat-note); }

  .dek {
    color: var(--ink-soft);
  }

  .post-foot {
    margin-top: var(--space-5);
    border-top: var(--border-hair);
    padding-top: var(--space-3);
  }

  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3);
    list-style: none;
    padding: 0;
  }

  .tag {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--ink-soft);
  }

  .tag:hover {
    color: var(--cobalt-deep);
  }
</style>

<style is:global>
  /* Long-form prose typography. Global (not scoped) because it must reach
     the rendered markdown, which Astro injects without scope hashes. */
  .prose {
    counter-reset: sidenote; /* powers <Sidenote> auto-numbering */
  }

  .prose > * + * {
    margin-top: var(--space-3);
  }

  /* Desktop only: make each text block the containing block for a sidenote
     authored inside it, so the note anchors to the paragraph (right edge + top)
     rather than to the inline marker. Global because these <p>/<li> come from
     rendered markdown and carry no scope hash. Matches Sidenote's breakpoint. */
  @media (min-width: 70rem) {
    .prose :is(p, li, blockquote) {
      position: relative;
    }
  }

  .prose h2,
  .prose h3 {
    margin-top: var(--space-5);
  }

  .prose h2 {
    font-size: var(--text-xl);
    border-bottom: var(--border-hair);
    padding-bottom: var(--space-1);
  }

  .prose h3 {
    font-size: var(--text-lg);
  }

  .prose ul,
  .prose ol {
    padding-left: 1.4em;
  }

  .prose li + li {
    margin-top: var(--space-1);
  }

  .prose blockquote {
    border-left: 3px solid var(--ochre);
    padding-left: var(--space-3);
    color: var(--ink-soft);
    font-style: italic;
  }

  .prose code {
    font-family: var(--font-mono);
    font-size: 0.86em;
    background: var(--paper-2);
    padding: 0.12em 0.35em;
    border-radius: var(--radius);
  }

  .prose pre {
    border: var(--border-hair);
    border-radius: var(--radius);
    padding: var(--space-3);
    overflow-x: auto;
    font-size: 0.86rem;
    line-height: 1.55;
  }

  .prose pre code {
    background: none;
    padding: 0;
    font-size: inherit;
  }

  .prose img {
    border: var(--border-strong);
    border-radius: var(--radius);
  }

  .prose hr {
    border: 0;
    border-top: var(--border-strong);
    width: 4rem;
    margin-inline: 0;
    margin-block: var(--space-5);
  }
</style>
